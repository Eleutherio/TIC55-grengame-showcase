# Exemplo de .env para Django + PostgreSQL
# Copie este arquivo para grengame-backend/.env e ajuste os valores.

# PostgreSQL (usado pelo container postgres)
POSTGRES_DB=grengame
POSTGRES_USER=grengame
POSTGRES_PASSWORD=change-me

# Django
SECRET_KEY=change-me-with-a-random-secret-key
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0,*

# Origens CORS permitidas (separadas por vírgula)
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# URL do banco do backend (nome do servico Docker: postgres)
DATABASE_URL=postgresql://grengame:change-me@postgres:5432/grengame

# Servico de e-mail (opcional no ambiente local)
MAILERSEND_API_KEY=
MAILERSEND_TEMPLATE_ID=
MAILERSEND_FROM_EMAIL=
